<!DOCTYPE html>
<html class="dark" lang="es"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Admin: Control de Usuarios y Flota</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#56f91f",
                        "accent-cyan": "#00f5ff",
                        "background-light": "#f6f8f5",
                        "background-dark": "#14230f",
                    },
                    fontFamily: {
                        "display": ["Manrope", "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
                },
            },
        }
    </script>
<style>
        body {
            font-family: 'Manrope', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        /* Garantizar que los iconos Material Symbols se carguen correctamente */
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display min-h-screen pb-24">
<header class="sticky top-0 z-50 bg-background-light/80 dark:bg-background-dark/80 backdrop-blur-md border-b border-slate-200 dark:border-primary/10">
<div class="flex items-center p-4 justify-between">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-primary">menu</span>
<h1 class="text-lg font-extrabold tracking-tight">Gestión de Usuarios</h1>
</div>
<div class="flex items-center gap-4">
<button onclick="init()" class="p-2 rounded-full hover:bg-primary/10 transition-colors text-primary">
<span class="material-symbols-outlined">sync</span>
</button>
<div class="relative">
<span id="notif-badge" class="absolute top-0 right-0 h-2.5 w-2.5 rounded-full bg-primary ring-2 ring-background-dark hidden"></span>
<span class="material-symbols-outlined">notifications</span>
</div>
</div>
</div>
<div class="px-4">
<div class="flex gap-8 border-b border-slate-200 dark:border-primary/5">
<button onclick="cambiarTab('motorizados')" id="tab-moto" class="border-b-2 border-primary text-primary pb-3 pt-2 text-sm font-bold flex flex-col items-center justify-center">
Motorizados
</button>
<button onclick="cambiarTab('tiendas')" id="tab-tienda" class="border-b-2 border-transparent text-slate-500 dark:text-slate-400 pb-3 pt-2 text-sm font-bold flex flex-col items-center justify-center">
Tiendas
</button>
</div>
</div>
<div class="flex gap-3 p-3 overflow-x-auto no-scrollbar">
<button class="flex h-9 shrink-0 items-center justify-center gap-x-2 rounded-lg bg-primary/20 border border-primary/30 px-4">
<span class="text-primary text-sm font-bold uppercase tracking-wider">Activos</span>
<span class="material-symbols-outlined text-primary text-sm">expand_more</span>
</button>
<button class="flex h-9 shrink-0 items-center justify-center gap-x-2 rounded-lg bg-slate-100 dark:bg-slate-800 border border-transparent px-4">
<span class="text-slate-600 dark:text-slate-300 text-sm font-medium">Bloqueados</span>
<span class="material-symbols-outlined text-slate-400 text-sm">expand_more</span>
</button>
<button class="flex h-9 shrink-0 items-center justify-center gap-x-2 rounded-lg bg-slate-100 dark:bg-slate-800 border border-transparent px-4">
<span class="text-slate-600 dark:text-slate-300 text-sm font-medium">Pendientes</span>
<span class="material-symbols-outlined text-slate-400 text-sm">expand_more</span>
</button>
</div>
</header>

<main id="main-content" class="p-4 space-y-4">
    <div class="text-center py-20 text-slate-500 dark:text-slate-400">
        <span class="material-symbols-outlined animate-spin text-4xl mb-2 text-primary">sync</span>
        <p class="text-xs font-bold uppercase tracking-widest">Sincronizando Usuarios...</p>
    </div>
</main>

<nav class="fixed bottom-0 left-0 right-0 z-50 bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl border-t border-slate-200 dark:border-primary/10 px-4 pb-6 pt-2">
<div class="flex justify-between items-center max-w-lg mx-auto">
<a class="flex flex-col items-center gap-1 text-primary" href="#">
<span class="material-symbols-outlined font-bold">group</span>
<span class="text-[10px] font-bold uppercase tracking-tighter">Usuarios</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary transition-colors" href="#">
<span class="material-symbols-outlined">two_wheeler</span>
<span class="text-[10px] font-bold uppercase tracking-tighter">Flota</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary transition-colors" href="#">
<span class="material-symbols-outlined">verified_user</span>
<span class="text-[10px] font-bold uppercase tracking-tighter">Auditoría</span>
</a>
<a class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary transition-colors" href="#">
<span class="material-symbols-outlined">settings</span>
<span class="text-[10px] font-bold uppercase tracking-tighter">Ajustes</span>
</a>
</div>
</nav>
<button class="fixed bottom-24 right-4 z-40 size-14 rounded-full bg-primary text-background-dark flex items-center justify-center shadow-[0_8px_30px_rgba(86,249,31,0.4)] transition-transform active:scale-90">
<span class="material-symbols-outlined text-3xl font-bold">add</span>
</button>

<script>
    // URL DE TU API (Asegúrate que config.js la tenga)
    let db = { motorizados: [], tiendas: [] };
    let currentTab = 'motorizados';

    // Función de inicio robusta
    async function init() {
        try {
            const response = await fetch(API_URL);
            db = await response.json();
            
            // Actualizar Badge Notificaciones (ejemplo)
            const badge = document.getElementById('notif-badge');
            const totalPendientes = (db.motorizados || []).length + (db.tiendas || []).length;
            if(totalPendientes > 0) {
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }

            render();
        } catch (error) {
            console.error("Error cargando base de datos");
            document.getElementById('main-content').innerHTML = `
                <p class="text-center py-10 text-red-500 text-xs font-bold uppercase">Error de conexión</p>
            `;
        }
    }

    function render() {
        const container = document.getElementById('main-content');
        container.innerHTML = "";

        // Obtener lista según pestaña activa
        const list = currentTab === 'motorizados' ? (db.motorizados || []) : (db.tiendas || []);

        if (list.length === 0) {
            container.innerHTML = `
                <p class="text-center py-10 text-slate-500 text-xs font-bold uppercase tracking-widest">Sin solicitudes pendientes</p>
            `;
            return;
        }

        // Renderizar CADA tarjeta respetando TU DISEÑO ORIGINAL
        list.forEach((item, index) => {
            const esMoto = currentTab === 'motorizados';
            const nombre = item.nombre || item.nombreTienda || "Sin Nombre";
            const idCedula = item.cedula || item.id || "N/A";
            const ciudad = item.ciudad || "Sector pendiente";
            const telefono = item.telefono || "";
            const avatarUrl = item.avatar || `https://ui-avatars.com/api/?name=${nombre}&background=56f91f&color=14230f`;

            // Decidir color y estado basado en PENDIENTE
            const colorStatus = esMoto ? 'primary' : 'accent-cyan';
            const statusText = 'PENDIENTE';
            const iconoHeader = esMoto ? 'moped' : 'store';

            // AQUÍ ESTÁ TU DISEÑO ORIGINAL EXACTO CON DATOS INYECTADOS
            container.innerHTML += `
            <div class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-primary/5 overflow-hidden shadow-sm">
                <div class="p-4">
                    <div class="flex gap-4">
                        <div class="relative size-16 shrink-0">
                            ${esMoto ? 
                                `<img alt="Avatar" class="size-16 rounded-lg object-cover grayscale" src="${avatarUrl}"/>` :
                                `<div class="size-16 rounded-lg bg-primary/20 flex items-center justify-center text-primary"><span class="material-symbols-outlined text-3xl">store</span></div>`
                            }
                            <span class="absolute -bottom-1 -right-1 flex h-4 w-4 rounded-full bg-slate-400 border-2 border-white dark:border-slate-900"></span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="font-bold text-slate-900 dark:text-slate-50 truncate">${nombre}</h3>
                                    <p class="text-xs text-slate-500 dark:text-slate-400">ID: ${idCedula} • ${ciudad}</p>
                                </div>
                                <span class="material-symbols-outlined text-slate-400">hourglass_empty</span>
                            </div>
                            <div class="mt-2 bg-slate-100 dark:bg-slate-800 rounded-lg h-2 w-full overflow-hidden loading-pulse">
                                <div class="bg-primary h-full w-1/2 rounded-full"></div>
                            </div>
                            <p class="mt-1 text-[10px] text-slate-400 font-medium">Esperando validación</p>
                        </div>
                    </div>
                    
                    <div class="mt-4 flex gap-2">
                        <button onclick="contactar('${telefono}')" class="flex-1 flex items-center justify-center gap-1.5 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 h-9 text-xs font-bold uppercase transition-all hover:bg-slate-200 dark:hover:bg-slate-700">
                            <span class="material-symbols-outlined text-sm">visibility</span>
                            WhatsApp
                        </button>
                        <button onclick="gestionar('${item.id}', 'ACTIVO', '${telefono}', '${nombre}', '${item.password}', '${idCedula}')" class="flex-1 flex items-center justify-center gap-1.5 rounded-lg bg-accent-cyan/10 text-accent-cyan border border-accent-cyan/20 h-9 text-xs font-bold uppercase transition-all hover:bg-accent-cyan/20">
                            <span class="material-symbols-outlined text-sm">check_circle</span>
                            Aprobar
                        </button>
                    </div>
                </div>
            </div>`;
        });
    }

    async function gestionar(id, estado, telf, nombre, pass, user) {
        if(!confirm(`¿Aprobar acceso para ${nombre}?`)) return;
        
        // Mensaje WhatsApp estructurado
        let msg = `*KM0 - ACCESO CONCEDIDO*%0A👤 *User:* ${user}%0A🔑 *Pass:* ${pass}`;
        
        await fetch(API_URL, { method: 'POST', body: JSON.stringify({ accion: "gestionar_solicitud", id, nuevoEstado: estado }) });
        window.open(`https://api.whatsapp.com/send?phone=${telf}&text=${msg}`, '_blank');
        init(); // Recargar
    }

    function contactar(tel) {
        window.open(`https://wa.me/${tel}`, '_blank');
    }

    function cambiarTab(tab) {
        currentTab = tab;
        // Ajustar estilos de tabs originales
        const btnM = document.getElementById('tab-moto');
        const btnT = document.getElementById('tab-tienda');
        
        if(tab === 'motorizados') {
            btnM.className = "border-b-2 border-primary text-primary pb-3 pt-2 text-sm font-bold flex flex-col items-center justify-center";
            btnT.className = "border-b-2 border-transparent text-slate-500 pb-3 pt-2 text-sm font-bold flex flex-col items-center justify-center";
        } else {
            btnT.className = "border-b-2 border-primary text-primary pb-3 pt-2 text-sm font-bold flex flex-col items-center justify-center";
            btnM.className = "border-b-2 border-transparent text-slate-500 pb-3 pt-2 text-sm font-bold flex flex-col items-center justify-center";
        }
        render();
    }

    init();
</script>
</body>
</html>
